{
  "name": "pdf-merger",
  "version": "1.0.0",
  "private": true,
  "description": "A beautiful, portable drag-and-drop PDF merging application.",
  "author": "Tunahan Balci <tunahan.balci@example.com>",
  "main": "main.js",
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite & sleep 2 && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.pdfmerger.app",
    "productName": "PDFMerger",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "public/logo512.png"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/logo512.png"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
